      grid-template-columns: minmax(0, 1.25fr) minmax(320px, .75fr);
      gap: 18px;
      margin-top: 18px;
    }
    @media (max-width: 980px){ .grid{grid-template-columns:1fr} }

    section.card{
      border:1px solid var(--border);
      background:
        linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,.045));
