    .inner{padding: 18px}

    .section-title{
      display:flex; align-items:baseline; justify-content:space-between; gap: 12px;
      margin-bottom: 10px;
    }
    h2{
      margin:0;
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 1.8px;
      color: #e7f0ff;
    }
    .section-title small{color: var(--muted)}

    .rule{
      height:1px;
      background:
        linear-gradient(90deg, transparent, rgba(56,189,248,.55), rgba(168,85,247,.42), transparent);
      margin: 12px 0;
    }

    .item{
      border:1px solid var(--border);
      background: rgba(0,0,0,.17);
      border-radius: 18px;
      padding: 14px;
      margin-bottom: 12px;
      transition:.22s ease;
      position:relative;
      overflow:hidden;
    }
    .item:before{
      content:"";
      position:absolute;
      inset:0;
      background: radial-gradient(circle at 0% 0%, rgba(56,189,248,.10), transparent 34%);
      pointer-events:none;
    }
    .item:hover{
      transform:translateY(-2px);
      border-color:rgba(56,189,248,.38);
      box-shadow:0 12px 30px rgba(0,0,0,.22);
    }
    .item:last-child{margin-bottom:0}
    .meta{
      display:flex; align-items:flex-start; justify-content:space-between; gap: 10px;
      flex-wrap: wrap;
      position:relative;
    }
    .where{font-weight: 850; color:#ffffff}
    .role{color: var(--muted); font-size: 13px; margin-top: 2px}
    .when{
      color: #d6e5ff;
      font-size: 12.5px;
      border:1px solid rgba(255,255,255,.14);
      padding:5px 9px;
      border-radius:999px;
      background:rgba(56,189,248,.08);
    }

    ul{margin:8px 0 0 18px; padding:0; position:relative}
    li{margin:6px 0; color:#dce9ff}
    li::marker{color:var(--accent)}

    .tags{display:flex; flex-wrap:wrap; gap:8px; margin-top: 12px}
    .tag{
      border:1px solid rgba(255,255,255,.16);
      background: rgba(56,189,248,.12);
      padding: 7px 10px;
      border-radius: 999px;
      font-size: 12.5px;
      color: #e1f3ff;
    }
    .tag.alt{background: rgba(168,85,247,.12)}
    .tag.green{background: rgba(34,197,94,.12)}

    .cols{
      display:grid;
      grid-template-columns: repeat(2, minmax(0,1fr));
      gap: 10px;
    }
    @media (max-width: 520px){ .cols{grid-template-columns:1fr} }

    .mini{
      border:1px solid var(--border);
      background:
        linear-gradient(135deg, rgba(255,255,255,.08), rgba(255,255,255,.035));
      border-radius: 18px;
      padding: 13px;
      color: var(--muted);
      min-height:86px;
    }
    .mini b{display:block; color: var(--text); margin-bottom: 5px}

    [data-lang]{display:none}
    [data-lang].active{display:block}

    footer{
      margin-top: 20px;
      color: var(--muted);
      text-align:center;
      font-size: 12.5px;
    }

    @media print{
      .nav, .actions, .social, .badge, .robot-strip{display:none !important}
      body{background:#fff; color:#111827}
      body:before, body:after, .hero-card:after, .avatar:before, section.card:before{display:none !important}
      .hero-card, section.card, .item, .mini{box-shadow:none !important; background:#fff !important}
      .chip, .contact a, .contact span, .tag{background:#fff !important; color:#111827 !important; border-color:#d1d5db !important}
      a{text-decoration:none}
    }
  </style>
</head>
