    .hero-bottom{
      position:relative;
      border-top:1px solid var(--border);
      padding: 15px 22px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap: 10px;
      flex-wrap: wrap;
      background:rgba(0,0,0,.13);
