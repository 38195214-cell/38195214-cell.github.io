      --bg2:#0b1730;
      --panel: rgba(255,255,255,.075);
      --panel2: rgba(255,255,255,.11);
      --border: rgba(255,255,255,.16);
      --text: #eef5ff;
      --muted: #b5c6dc;

      --accent: #38bdf8;
      --accent2: #a855f7;
      --accent3: #22c55e;
      --warm:#f59e0b;

      --shadow: 0 22px 80px rgba(0,0,0,.42);
      --radius: 24px;
      --max: 1180px;
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial, "Apple Color Emoji","Segoe UI Emoji";
      background:
        radial-gradient(900px 520px at 12% 8%, rgba(56,189,248,.24), transparent 62%),
        radial-gradient(760px 460px at 88% 12%, rgba(168,85,247,.21), transparent 58%),
        radial-gradient(700px 420px at 72% 85%, rgba(34,197,94,.12), transparent 58%),
        linear-gradient(135deg, var(--bg), var(--bg2) 45%, #100b25);
      color: var(--text);
      line-height:1.6;
      overflow-x:hidden;
    }

    body:before{
      content:"";
      position:fixed;
      inset:0;
      pointer-events:none;
      opacity:.18;
      background-image:
        linear-gradient(rgba(255,255,255,.06) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.06) 1px, transparent 1px);
      background-size: 42px 42px;
      mask-image: linear-gradient(to bottom, black 0%, transparent 85%);
    }

    body:after{
      content:"";
      position:fixed;
      inset:-30%;
      pointer-events:none;
      background:
        conic-gradient(from 180deg at 50% 50%, transparent, rgba(56,189,248,.06), transparent, rgba(168,85,247,.07), transparent);
      animation: rotateGlow 24s linear infinite;
      opacity:.65;
      z-index:-1;
    }
    @keyframes rotateGlow{to{transform:rotate(360deg)}}

    a{color:inherit; text-decoration:none}
    a:hover{text-decoration:underline; text-underline-offset:3px}

    .container{max-width:var(--max); margin:0 auto; padding: 20px 20px 72px}

    .nav{
      position:sticky; top:0; z-index:50;
      backdrop-filter: blur(16px);
      background: linear-gradient(180deg, rgba(7,17,31,.92), rgba(7,17,31,.62));
      border-bottom: 1px solid var(--border);
    }
    .nav-inner{
      max-width: var(--max);
      margin: 0 auto;
      padding: 13px 20px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap: 12px;
    }
    .id{
      display:flex; align-items:center; gap:12px; min-width: 250px;
    }
    .mark{
      width: 40px; height: 40px; border-radius: 14px;
      background:
        linear-gradient(135deg, rgba(56,189,248,.9), rgba(168,85,247,.76));
      border: 1px solid rgba(255,255,255,.24);
      box-shadow: 0 0 30px rgba(56,189,248,.32);
      display:grid; place-items:center;
      font-weight: 900;
      letter-spacing:.8px;
      color:white;
    }
    .id b{font-size: 14px; letter-spacing:.25px}
    .id small{display:block; color:var(--muted); font-size: 12px; line-height: 1.15}

    .links{
      display:flex; gap:9px; flex-wrap:wrap; justify-content:center;
    }
    .chip{
      border:1px solid var(--border);
      background: rgba(255,255,255,.055);
      padding: 8px 12px;
      border-radius: 999px;
      font-size: 13px;
      color: var(--muted);
      transition:.22s ease;
    }
    .chip:hover{
      transform:translateY(-1px);
      border-color: rgba(56,189,248,.65);
      color: var(--text);
      text-decoration:none;
      box-shadow:0 0 24px rgba(56,189,248,.12);
    }

    .actions{display:flex; gap:10px; align-items:center; justify-content:flex-end; min-width: 230px}
    .btn{
      border:1px solid rgba(255,255,255,.20);
      background: linear-gradient(135deg, rgba(56,189,248,.28), rgba(168,85,247,.22));
      padding: 9px 13px;
      border-radius: 999px;
      cursor:pointer;
      font-weight: 750;
      color: var(--text);
      display:inline-flex; align-items:center; gap:8px;
      box-shadow:0 8px 30px rgba(56,189,248,.12);
      transition:.22s ease;
    }
    .btn:hover{transform:translateY(-1px); border-color: rgba(56,189,248,.75); text-decoration:none}
    .btn.secondary{
      background: rgba(255,255,255,.055);
      color: var(--muted);
      font-weight: 650;
    }

    @media (max-width: 900px){
      .nav-inner{align-items:flex-start; flex-direction:column}
      .id,.actions{min-width:unset}
      .actions{width:100%; justify-content:flex-start}
    }

    .hero{padding: 28px 0 12px}
    .hero-card{
      border:1px solid rgba(255,255,255,.18);
      background:
        linear-gradient(135deg, rgba(255,255,255,.13), rgba(255,255,255,.045)),
        linear-gradient(90deg, rgba(56,189,248,.10), rgba(168,85,247,.08));
      border-radius: calc(var(--radius) + 10px);
      box-shadow: var(--shadow);
      overflow:hidden;
      position: relative;
    }
    .hero-card:before{
      content:"";
      position:absolute; inset:0;
      background:
        radial-gradient(circle at 20% 20%, rgba(56,189,248,.22), transparent 28%),
        radial-gradient(circle at 78% 24%, rgba(168,85,247,.22), transparent 24%),
        linear-gradient(90deg, transparent 0%, rgba(255,255,255,.055) 48%, transparent 100%);
      opacity:.72;
      pointer-events:none;
    }
    .hero-card:after{
      content:"⚙";
      position:absolute;
      right:28px;
      top:18px;
      font-size:130px;
      line-height:1;
      color:rgba(255,255,255,.055);
      animation: gear 18s linear infinite;
      pointer-events:none;
    }
    @keyframes gear{to{transform:rotate(360deg)}}

    .hero-top{
      position:relative;
      padding: 28px 24px 22px;
      display:grid;
      grid-template-columns: 172px 1fr;
      gap: 22px;
      align-items:center;
    }
    @media (max-width: 740px){
      .hero-top{grid-template-columns:1fr; text-align:center}
    }

    .avatar{
      width: 158px; height: 158px;
      border-radius: 999px;
      overflow:hidden;
      border: 2px solid rgba(56,189,248,.42);
      background:
        radial-gradient(circle at 35% 30%, rgba(56,189,248,.35), transparent 35%),
        linear-gradient(135deg, rgba(168,85,247,.20), rgba(255,255,255,.05));
      box-shadow: 0 14px 45px rgba(0,0,0,.38), 0 0 38px rgba(56,189,248,.16);
      margin: 0 auto;
      position:relative;
    }
    .avatar:before{
      content:"";
      position:absolute;
      inset:-8px;
      border-radius:inherit;
      border:1px dashed rgba(255,255,255,.22);
      animation: gear 20s linear infinite reverse;
    }
    .avatar img{width:100%; height:100%; object-fit:cover; display:block}
    .avatar .ph{
      height:100%;
      display:grid; place-items:center;
      color: var(--muted);
      font-size: 12px;
      padding: 14px;
      text-align:center;
    }

    h1{
      margin:0;
      font-size: clamp(32px, 5vw, 54px);
      line-height: 1.02;
      letter-spacing:-1.6px;
    }
    .subtitle{
      margin: 10px 0 12px;
      color: #d8e7ff;
      font-weight: 750;
      letter-spacing:.25px;
      font-size: 18px;
    }

    .robot-strip{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      margin:12px 0 0;
    }
    .robot-icon{
      width:44px;
      height:44px;
      display:grid;
      place-items:center;
      border-radius:16px;
      border:1px solid rgba(255,255,255,.16);
      background:rgba(255,255,255,.075);
      box-shadow: inset 0 1px 0 rgba(255,255,255,.08);
      font-size:21px;
    }

    .contact{
