  <script>
    const langBtn=document.getElementById('langBtn');
    const blocks=Array.from(document.querySelectorAll('[data-lang]'));
    const summaries=Array.from(document.querySelectorAll('[data-lang-summary]'));
    function setLang(lang){
      blocks.forEach(b=>b.classList.toggle('active', b.getAttribute('data-lang')===lang));
      summaries.forEach(s=>s.style.display=s.getAttribute('data-lang-summary')===lang?'block':'none');
      document.documentElement.lang=lang;
      langBtn.textContent=lang==='en'?'🌐 EN':'🌐 ES';
      langBtn.setAttribute('aria-label', lang==='en'?'Switch language to Spanish':'Cambiar idioma a inglés');
      localStorage.setItem('cv_lang', lang);
    }
    setLang(localStorage.getItem('cv_lang')==='es'?'es':'en');
    langBtn.addEventListener('click',()=>setLang((document.documentElement.lang||'en')==='en'?'es':'en'));
    function goTo(section){
      const lang=document.documentElement.lang||'en';
      const id=lang==='es'?`${section}-es`:section;
      const el=document.getElementById(id);
      if(el) el.scrollIntoView({behavior:'smooth',block:'start'});
    }
  </script>
